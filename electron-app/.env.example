# OAuth Proxy base URL — providers append /oauth/{provider}/... to this
# Do NOT include /oauth here (that would cause double /oauth/oauth/ paths)
VITE_OAUTH_PROXY_URL=http://localhost:7071/api

# Apple Music Developer Token
# See ../docs/GETTING_OAUTH_CREDENTIALS.md for instructions
VITE_APPLE_MUSIC_DEVELOPER_TOKEN=your_jwt_token_here

# Future: OpenAI API for AI Commentary
# VITE_OPENAI_API_KEY=your_openai_key
